void solve(int index,vector<int> output,vector<vector<int>> & ans,vector<int> & v)
{
    if(index>=v.size())
    {
        ans.push_back(output);
        return;
    }
    
     solve(index+1,output,ans,v);
    output.push_back(v[index]);
    solve(index+1,output,ans,v);
   
}


vector<vector<int>> pwset(vector<int>v)
{
    vector<vector<int>> ans;
    vector<int> output;
    solve(0,output,ans,v);
    return ans;
}
