
void levelorderTraversal(BinaryTreeNode<int> *root,vector<int> &ans)
{
    if(root==NULL)
    {
        return;
    }
    
    queue<BinaryTreeNode<int>*> q;
    q.push(root);
    
    while(!q.empty())
    {
        auto node=q.front();
        q.pop();
        ans.push_back(node->val);
        if(node->left)
        {
            q.push(node->left);
        }
        if(node->right)
        {
            q.push(node->right);
        }
    }
}


vector<int> getLevelOrder(BinaryTreeNode<int> *root)
{
    //  Write your code here
    vector<int> ans;
    levelorderTraversal(root,ans);
    return ans;
}
