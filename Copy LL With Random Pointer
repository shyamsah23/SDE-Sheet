

void insertAtTail(LinkedListNode<int>* &cloneHead,LinkedListNode<int>* &cloneTail,int d)
{
    LinkedListNode<int> *n=new LinkedListNode<int> (d);
    if(cloneHead==NULL)
    {
        cloneHead=n;
        cloneTail=n;
        return;
    }
    cloneTail->next=n;
    cloneTail=cloneTail->next;
}

LinkedListNode<int> *cloneRandomList(LinkedListNode<int> *head)
{
    // Write your code here.
    
    // Step 1: Copy Linked List without AnY random Pointer
    
    LinkedListNode<int> * cloneHead=NULL;
    LinkedListNode<int>* cloneTail=NULL;
    
    LinkedListNode<int>* temp=head;
    while(temp!=NULL)
    {
        insertAtTail(cloneHead,cloneTail,temp->data);
        temp=temp->next;
    }
    
    LinkedListNode<int> * temp2=cloneHead;
    temp=head;
    
    // Step 2: Mapping
    unordered_map<LinkedListNode<int>*,LinkedListNode<int>*> m;
    
    
    while(temp!=NULL)
    {
        m[temp]=temp2;
        temp=temp->next;
        temp2=temp2->next;
    }
    
    
    // step 3: copy With random Pointer
    
    temp2=cloneHead;
    temp=head;
    
    while(temp!=NULL)
    {
        temp2->random=m[temp->random];
        temp=temp->next;
        temp2=temp2->next;
    }
    
    
    return cloneHead;
    
    
    
}

